# =============================================================================
# LEADFORGE AI - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://leadforge:leadforge_password@localhost:5432/leadforge
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API KEYS - Get these from the respective services
# =============================================================================

# OpenAI API (for AI lead scoring, outreach generation, sales assistant)
# Get it here: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic/Claude API (alternative to OpenAI)
# Get it here: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

# NeverBounce (for email validation)
# Get it here: https://app.neverbounce.com/account/api
NEVERBOUNCE_API_KEY=your-neverbounce-key-here

# =============================================================================
# EMAIL DELIVERY
# =============================================================================

# SMTP Configuration (for sending outreach emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# SendGrid (alternative email service)
# Get it here: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-key-here

# =============================================================================
# SECURITY
# =============================================================================

# Generate a strong secret key for JWT tokens
# Use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================

# Enable proxy rotation for scraping
PROXY_ROTATION_ENABLED=true

# Proxy service credentials (if using residential proxies)
# Providers: BrightData, SmartProxy, Oxylabs
PROXY_SERVICE_URL=
PROXY_SERVICE_USERNAME=
PROXY_SERVICE_PASSWORD=

# Scraper behavior
SCRAPER_CONCURRENT_REQUESTS=5
SCRAPER_DELAY_MIN=1
SCRAPER_DELAY_MAX=3
SCRAPER_MAX_RETRIES=3

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# =============================================================================
# STRIPE BILLING (Future - prepare architecture)
# =============================================================================
# Get these here: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=

# PostHog for analytics
POSTHOG_KEY=
POSTHOG_HOST=
